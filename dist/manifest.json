{
  "manifest_version": 3,
  "name": "ChatGPT Summarize UI Clone",
  "description": "A UI-only Chrome extension clone with iframe injection and onboarding.",
  "version": "0.1.0",
  "action": {
    "default_title": "ChatGPT Summarize",
    "default_icon": {
      "16": "icons/logo-16.png",
      "32": "icons/logo-32.png",
      "48": "icons/logo-48.png",
      "128": "icons/logo-128.png"
    }
  },
  "background": {
    "service_worker": "assets/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["assets/content-script.js"],
      "matches": ["http://*/*", "https://*/*"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/logo-16.png",
    "32": "icons/logo-32.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "icons/logo-128.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
